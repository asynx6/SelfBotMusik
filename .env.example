# === ONLY boot secrets in .env ===
# Edit only if you know what you're doing.
# Live config (Lavalink, Guild, etc.) is in config.json — auto-generated on first boot.

# REQUIRED: Discord user token (NOT bot token; this is a selfbot).
# If you regenerate your token, restart Node.js so it's re-read.
TOKEN_USER=your_token

# OPTIONAL: Web dashboard port (default 3434).
WEB_PORT=3434